{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      { "source": "/cert/**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/certs/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
      }
    ]
  }
}
